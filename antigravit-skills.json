  "conventions": {
    "naming": {
      "components": "PascalCase (Dashboard.jsx)",
      "hooks": "camelCase com prefix 'use' (useAuth)",
      "utils": "camelCase (formatDate.js)",
      "styles": "Same as component (Dashboard.module.css)",
      "constants": "UPPER_SNAKE_CASE"
    },
    "structure": {
      "components": "feature/ComponentName/index.jsx",
      "hooks": "hooks/useHookName.js",
      "utils": "utils/utilityName.js",
      "services": "services/firebase.js"
    },
    "imports": {
      "order": "React → External → Internal → Styles",
      "relative": "Prefer absolute (@/) for internal"
    },
    "jsx": {
      "selfClosing": "Only for no children",
      "fragment": "Use <Fragment> or <>",
      "conditions": "Ternary for simple, && for side effects"
    },
    "hooks": {
      "custom": "use prefix, single responsibility",
      "dependencies": "Complete arrays, eslint warnings",
      "memo": "useMemo for expensive calculations"
    }
  },
