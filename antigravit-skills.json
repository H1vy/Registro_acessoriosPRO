        "pendingReturns": "Itens não retornados",
        "byResponsible": "Por responsável"
      },
      "export": "XLSX com formatação, múltiplas abas"
    },
    "reports": {
      "excel": "Export múltiplas sheets",
      "pdf": "Relatórios formatados",
