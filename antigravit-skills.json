{
  "version": "2.0",
  "project": {
    "name": "Registro de Acessórios Pro",
    "type": "Enterprise Web Application (SPA)",
    "description": "Sistema de gerenciamento de acessórios, movimentações patrimoniais e controle de estoque com funcionalidades de dashboard analítico e relatórios",
    "maturity": "Production-ready, multi-user, real-time"
  },
  "architecture": {
    "pattern": "Component-Based Architecture com Feature-Based Organization",
    "stateManagement": "React Context + Custom Hooks (sem library externa)",
    "dataFlow": "Unidirectional Data Flow com prop drilling controlado",
    "layering": {
      "presentation": "React Components (presentational + container)",
      "business": "Custom Hooks e util functions",
      "data": "Firebase SDK + LocalStorage Cache Layer"
    },
    "errorBoundaries": "Implementar Error Boundary para resiliência",
    "codeSplitting": "Dynamic imports para routes e heavy components"
  },
  "technologies": {
    "core": {
      "runtime": "Node.js 18+",
      "framework": "React 18+ com hooks",
      "buildTool": "Vite 5+ (dev server, build, preview)",
      "routing": "React Router v6+ (lazy routes)"
    },
    "frontend": [
      "React 18 (Concurrent features, automatic batching)",
      "React.lazy() + Suspense",
      "Custom Hooks (useMemo, useCallback, useTransition)",
      "Web Workers (para processamento pesado)"
    ],
    "icons": ["Lucide React (tree-shakeable)"],
    "charts": ["Recharts (com custom tooltip, responsive)"],
    "excel": ["XLSX (SheetJS) - with worker optimization"],
    "ui": ["CSS Modules + CSS Variables", "Framer Motion (animações)", "React DnD (drag-drop)"]
  },
  "backend": {
    "provider": "Firebase",
    "services": {
      "auth": "Firebase Auth (multi-provider: email/password, Google)",
      "database": "Cloud Firestore (real-time subscriptions)",
      "storage": "Cloud Storage (imagens/arquivos)",
      "functions": "Cloud Functions (server-side logic)"
    },
    "security": "Firestore Security Rules, Auth emiddleware"
  },
  "dataLayer": {
    "firestoreCollections": ["accessories", "responsibles", "movements", "users"],
    "indexes": "Compound indexes para queries frequentes",
    "caching": "Dual-layer: Firestore (primário) + localStorage (cache inicial)",
    "syncStrategy": "Optimistic UI updates com eventual consistency",
    "errorRecovery": "Retry logic, exponential backoff, offline persistence"
  },
  "dataModels": {
    "accessories": {
      "id": "string (Firestore doc ID)",
      "factoryCode": "string (unique, indexed)",
      "commercialName": "string",
      "category": "string (enum: 'equipment', 'tool', 'consumable', 'accessory')",
      "responsible": "string",
      "location": "string",
      "purchaseDate": "timestamp",
      "warrantyEnd": "timestamp",
      "status": "string (enum: 'available', 'in-use', 'maintenance', 'retired')",
      "metadata": "map (custom fields)",
      "createdAt": "timestamp",
      "updatedAt": "timestamp",
      "createdBy": "string (user id)"
    },
    "responsibles": {
      "id": "string",
      "name": "string",
      "email": "string",
      "department": "string (indexed)",
      "role": "string (enum: 'technician', 'manager', 'admin')",
      "phone": "string",
      "active": "boolean",
      "createdAt": "timestamp",
      "createdBy": "string"
    },
    "movements": {
      "id": "string",
      "accessoryId": "string (indexed)",
      "responsibleId": "string (indexed)",
      "type": "string (enum: 'checkout', 'return', 'transfer', 'maintenance')",
      "timestamp": "timestamp (indexed)",
      "author": "string (user id, indexed)",
      "soNumber": "string (Work Order)",
      "notes": "string",
      "attachments": "array (file URLs)",
      "annulled": "boolean",
      "annulmentReason": "string",
      "annulledBy": "string",
      "annulmentTimestamp": "timestamp",
      "isReturn": "boolean (legacy)",
      "returnInfo": {
        "returnedBy": "string",
        "timestamp": "timestamp",
        "condition": "string (enum: 'good', 'damaged', 'needs-maintenance')",
        "notes": "string"
      },
      "checkin": {
        "author": "string",
        "timestamp": "timestamp",
        "notes": "string"
      },
      "isDeleted": "boolean (soft delete)",
      "deletionReason": "string",
      "deletedBy": "string",
      "deletionTimestamp": "timestamp"
    },
    "users": {
      "id": "string (Firebase UID)",
      "username": "string",
      "email": "string",
      "role": "string (enum: 'user', 'admin', 'superadmin')",
      "permissions": "array (granular permissions)",
      "lastLogin": "timestamp",
      "createdAt": "timestamp",
      "createdBy": "string"
    }
  },
  "features": {
    "authentication": {
      "providers": ["email/password", "Google OAuth"],
      " MFA": false,
      "session": "JWT tokens via Firebase",
      "persist": "localStorage com encryption (simulated)",
      "roles": ["user", "admin", "superadmin"],
      "permissions": ["read", "write", "delete", "annul", "export", "admin"]
