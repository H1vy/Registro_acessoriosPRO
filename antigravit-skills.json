  "testing": {
    "strategy": "Pyramid: Unit (70%) → Integration (20%) → E2E (10%)",
    "coverage": "> 80% para lógica de negócio",
    "tools": {
      "unit": ["Vitest", "React Testing Library"],
      "e2e": ["Playwright ou Cypress"],
      "coverage": ["Vitest coverage"]
    },
    "patterns": {
      "components": "Render, fireEvent, await findBy*",
      "hooks": "RenderHook from @testing-library/react-hooks",
      "context": "Wrapper com Provider",
      "mocks": "Jest.fn(), mockFirebase"
    }
  },
  "security": {
    "inputValidation": "Zod ou custom validators",
